# ============================================
# MediaHub — Production Environment
# ============================================
# ALL variables below are REQUIRED in production.
# The app will crash on startup if any are missing.
#
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.

# ─── Supabase ───
# Your hosted Supabase project URL and keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Redis ───
# Managed Redis URL (e.g., Upstash, Redis Cloud, Railway)
REDIS_URL=redis://default:password@your-redis-host:6379

# ─── Encryption ───
# AES-256 key for encrypting tokens/API keys in DB
# Generate ONCE with: openssl rand -hex 32
# WARNING: Changing this key will make all existing encrypted data unreadable
TOKEN_ENCRYPTION_KEY=generate-a-real-64-char-hex-key-with-openssl-rand-hex-32

# ─── App URL ───
# Your production domain (MUST be HTTPS)
# This is used for OAuth redirect URIs, invitation links, and API referer headers
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com

# ─── Cron Secret ───
# REQUIRED in production. Protects /api/cron/* endpoints from unauthorized access.
# Generate with: openssl rand -hex 16
CRON_SECRET=generate-a-secret-here

# ─── Node Environment ───
NODE_ENV=production

# ============================================
# CHECKLIST BEFORE GOING LIVE
# ============================================
# 1. Set all variables above with real production values
# 2. Run database migrations: apply all files in supabase/migrations/
# 3. Set up OAuth redirect URIs in each platform's developer console:
#    - Instagram: https://app.yourdomain.com/api/callback/instagram
#    - YouTube:   https://app.yourdomain.com/api/callback/youtube
#    - LinkedIn:  https://app.yourdomain.com/api/callback/linkedin
#    - Google Drive: https://app.yourdomain.com/api/callback/google-drive
# 4. Set up cron job to hit: POST https://app.yourdomain.com/api/cron/token-refresh
#    with header "Authorization: Bearer {CRON_SECRET}" — run daily
# 5. Start the worker process: npx tsx worker.ts
# 6. Ensure Redis is accessible from your server
# 7. Ensure Supabase is accessible from your server
