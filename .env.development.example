# ============================================
# MediaHub — Development Environment
# ============================================
# Copy this file to .env.local and fill in the values.
# Run: cp .env.development.example .env.local

# ─── Supabase (self-hosted Docker) ───
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ─── Redis (local Docker) ───
REDIS_URL=redis://localhost:6379

# ─── Encryption ───
# AES-256 key for encrypting tokens/API keys in DB
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2

# ─── App URL ───
# In development, we use HTTPS via local-ssl-proxy (port 3443 → 3000)
# This is required for Instagram/Meta OAuth which mandates HTTPS
NEXT_PUBLIC_APP_URL=https://localhost:3443

# ─── Cron Secret (optional in dev) ───
# Protects /api/cron/* endpoints. If unset, cron endpoints are blocked.
# CRON_SECRET=dev-cron-secret

# ─── Notes ───
# 1. Start Supabase: docker compose up -d
# 2. Start Redis: included in docker-compose
# 3. Start dev server with HTTPS: npm run dev:https
# 4. App available at: https://localhost:3443
# 5. Supabase Studio: http://localhost:54323
# 6. Platform credentials (Instagram, YouTube, etc.) are managed via Settings UI
